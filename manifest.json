{
  "manifest_version": 3,
  "name": "Picture-in-Picture",
  "version": "1.0",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "action": {
    "default_title": "Toggle PiP"
  },
  "background": {
    "service_worker": "background.js"
  }
}